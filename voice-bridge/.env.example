# Copy to .env and adjust. All values have defaults (see config.py); these are the ones you'll set.

# --- HomeHub API (the .NET app) ---
HOMEHUB_API_BASE_URL=http://home-server:5220
HOMEHUB_HTTP_TIMEOUT=30

# --- Wake word (openWakeWord) ---
# Point at a custom-trained "Hey Cleo" model. If unset, a pretrained WAKE_MODEL is used as a stand-in.
WAKE_MODEL_PATH=/opt/homehub-voice/models/hey_cleo.onnx
WAKE_MODEL=hey_jarvis
WAKE_FRAMEWORK=onnx
WAKE_THRESHOLD=0.5
WAKE_PHRASE=Hey Cleo

# --- Audio capture ---
# MIC_DEVICE=            # sounddevice name/index; leave blank for the system default
VAD_AGGRESSIVENESS=2
START_TIMEOUT_MS=3000
END_SILENCE_MS=900
MIN_SPEECH_MS=300
MAX_UTTERANCE_MS=15000

# --- TTS (Piper, "norman" voice) ---
PIPER_BIN=piper
PIPER_MODEL=/opt/homehub-voice/voices/en_US-norman-medium.onnx
TTS_SAMPLE_RATE=22050
# APLAY_DEVICE=          # ALSA device for `aplay -D`; blank for default

# --- Conversation ---
HISTORY_TURNS=4
